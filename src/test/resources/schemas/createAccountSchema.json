{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "customerId",
    "type",
    "balance"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "customerId": {
      "type": "integer"
    },
    "type": {
      "type": "string",
      "enum": ["CHECKING", "SAVINGS", "LOAN"]
    },
    "balance": {
      "type": "number"
    }
  },
  "additionalProperties": false
}